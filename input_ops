#!/bin/bash

#>>>>>>>>
# include the contents of this file at the top of any script that needs to use the op_scripting
#   package, but you can't guarantee it is installed or where it is.
script_dir=$(echo -e ${PATH//:/\\n} | grep -E "/op_scripting\$" | head - -n1)
if [[ -z "$script_dir" ]] && [[ -f "$HOME/.op_scripting/path" ]]; then
    script_dir="$(cat "$HOME/.op_scripting/path" | grep -E "/op_scripting\$" | head - -n1)"
    if [[ ! -z "$script_dir" ]]; then
        if [[ ! -d "$script_dir" ]] || [[ ! -f "$script_dir/git_ops" ]] ; then
            script_dir=''
        else
            PATH="$PATH:$script_dir"
            export PATH
            export script_dir
        fi
    fi
fi
if [[ -z "$script_dir" ]]; then
    (( arg = ${#BASH_ARGV[*]} - 1 ))
    if [[ "$0" = '-su' ]] || [[ "$0" = '-bash' ]] || [[ "$(basename "$0")" = "bash" ]]; then
        target="${BASH_ARGV[$arg]}"
        search_dir="$(dirname "$(realpath "$target")")"
        [[ "$search_dir" = '.' ]] && search_dir="$PWD"
    else
        search_dir="$(dirname "$(realpath "$0")")"
        target="$0"
    fi
    while [[ "$search_dir" != "/" && ! -d "$search_dir/op_scripting" ]]; do
        search_dir="$(dirname "$search_dir")"
    done
    [[ "$search_dir" != "/" ]] && script_dir="$search_dir/op_scripting"
    if [[ ! -z "$script_dir" ]]; then
        PATH="$PATH:$script_dir"
        export PATH
        export script_dir
        mkdir -p "$HOME/.op_scripting"
        echo "$script_dir" > "$HOME/.op_scripting/path"
    fi
fi
if [[ -z "$script_dir" ]]; then
    echo -e "Unable to locate the op_scripting package dir.\n"\
            "\tnot referenced in \$PATH,\n"\
            "\tnot contained in '$HOME/.op_scripting/path'\n"\
            "\tnot associated with '$target'." >&2
    if [[ "$target" != "$0" ]]; then
        return 1
    else
        exit 1
    fi
fi
